{
  "name": "optimistic",
  "version": "0.1.0",
  "private": true,
  "description": "Optimistic — Next.js marketing site + Yubi Design System monorepo (token-driven, multi-framework).",
  "workspaces": [
    "packages/tokens",
    "packages/core",
    "packages/react",
    "packages/angular"
  ],
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "tokens:css": "node tokens/build-css.mjs",
    "predev": "node tokens/build-css.mjs",
    "prebuild": "node tokens/build-css.mjs",
    "tokens:build": "npm run build --workspace=@yubi/tokens",
    "ds:build": "npm run tokens:build && npm run build --workspace=@yubi/core && npm run build --workspace=@yubi/react",
    "ds:dev": "npm run build --workspace=@yubi/core -- --watch",
    "site:build": "npm run tokens:build && node scripts/build-site.mjs"
  },
  "dependencies": {
    "@react-three/fiber": "^9.6.1",
    "@types/three": "^0.185.0",
    "lucide-react": "^1.23.0",
    "next": "16.2.9",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "three": "^0.185.0"
  },
  "devDependencies": {
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.2.9",
    "typescript": "^5"
  }
}
