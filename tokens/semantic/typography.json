{
  "$description": "Optimistic type scale. Sizes in px; leading matched to our components (tight display, loose body). Inter (light for display) + Geist Mono.",
  "text-style": {
    "display-1": { "$type": "typography", "$value": { "fontFamily": "{font.family.base}", "fontWeight": "{font.weight.light}", "fontSize": "{font.size.72}", "lineHeight": "{font.line-height.display}", "letterSpacing": "{font.letter-spacing.display}" }, "$description": "Display 1" },
    "display-2": { "$type": "typography", "$value": { "fontFamily": "{font.family.base}", "fontWeight": "{font.weight.light}", "fontSize": "{font.size.60}", "lineHeight": "{font.line-height.display}", "letterSpacing": "{font.letter-spacing.display}" }, "$description": "Display 2" },
    "display-3": { "$type": "typography", "$value": { "fontFamily": "{font.family.base}", "fontWeight": "{font.weight.light}", "fontSize": "{font.size.54}", "lineHeight": "{font.line-height.display}", "letterSpacing": "{font.letter-spacing.display}" }, "$description": "Display 3" },

    "header-1": { "$type": "typography", "$value": { "fontFamily": "{font.family.base}", "fontWeight": "{font.weight.semibold}", "fontSize": "{font.size.36}", "lineHeight": "{font.line-height.heading}", "letterSpacing": "{font.letter-spacing.tight}" } },
    "header-2": { "$type": "typography", "$value": { "fontFamily": "{font.family.base}", "fontWeight": "{font.weight.semibold}", "fontSize": "{font.size.28}", "lineHeight": "{font.line-height.heading}", "letterSpacing": "{font.letter-spacing.tight}" } },
    "header-3": { "$type": "typography", "$value": { "fontFamily": "{font.family.base}", "fontWeight": "{font.weight.semibold}", "fontSize": "{font.size.24}", "lineHeight": "{font.line-height.heading}", "letterSpacing": "{font.letter-spacing.snug}" } },
    "header-4": { "$type": "typography", "$value": { "fontFamily": "{font.family.base}", "fontWeight": "{font.weight.semibold}", "fontSize": "{font.size.18}", "lineHeight": "{font.line-height.heading}", "letterSpacing": "{font.letter-spacing.snug}" } },
    "header-5": { "$type": "typography", "$value": { "fontFamily": "{font.family.base}", "fontWeight": "{font.weight.semibold}", "fontSize": "{font.size.14}", "lineHeight": "{font.line-height.heading}", "letterSpacing": "{font.letter-spacing.normal}" } },

    "subheading-1": { "$type": "typography", "$value": { "fontFamily": "{font.family.base}", "fontWeight": "{font.weight.medium}", "fontSize": "{font.size.24}", "lineHeight": "{font.line-height.snug}", "letterSpacing": "{font.letter-spacing.snug}" } },
    "subheading-2": { "$type": "typography", "$value": { "fontFamily": "{font.family.base}", "fontWeight": "{font.weight.medium}", "fontSize": "{font.size.18}", "lineHeight": "{font.line-height.snug}", "letterSpacing": "{font.letter-spacing.normal}" } },
    "subheading-3": { "$type": "typography", "$value": { "fontFamily": "{font.family.base}", "fontWeight": "{font.weight.medium}", "fontSize": "{font.size.16}", "lineHeight": "{font.line-height.snug}", "letterSpacing": "{font.letter-spacing.normal}" } },
    "subheading-4": { "$type": "typography", "$value": { "fontFamily": "{font.family.base}", "fontWeight": "{font.weight.medium}", "fontSize": "{font.size.14}", "lineHeight": "{font.line-height.snug}", "letterSpacing": "{font.letter-spacing.normal}" } },

    "body-1": { "$type": "typography", "$value": { "fontFamily": "{font.family.base}", "fontWeight": "{font.weight.regular}", "fontSize": "{font.size.16}", "lineHeight": "{font.line-height.relaxed}", "letterSpacing": "{font.letter-spacing.normal}" }, "$description": "Recommended reading size" },
    "body-2": { "$type": "typography", "$value": { "fontFamily": "{font.family.base}", "fontWeight": "{font.weight.regular}", "fontSize": "{font.size.14}", "lineHeight": "{font.line-height.relaxed}", "letterSpacing": "{font.letter-spacing.normal}" } },
    "body-3": { "$type": "typography", "$value": { "fontFamily": "{font.family.base}", "fontWeight": "{font.weight.regular}", "fontSize": "{font.size.12}", "lineHeight": "{font.line-height.relaxed}", "letterSpacing": "{font.letter-spacing.normal}" } },
    "body-4": { "$type": "typography", "$value": { "fontFamily": "{font.family.base}", "fontWeight": "{font.weight.regular}", "fontSize": "{font.size.11}", "lineHeight": "{font.line-height.relaxed}", "letterSpacing": "{font.letter-spacing.normal}" } },
    "body-5": { "$type": "typography", "$value": { "fontFamily": "{font.family.base}", "fontWeight": "{font.weight.regular}", "fontSize": "{font.size.10}", "lineHeight": "{font.line-height.relaxed}", "letterSpacing": "{font.letter-spacing.normal}" } },
    "body-6": { "$type": "typography", "$value": { "fontFamily": "{font.family.base}", "fontWeight": "{font.weight.regular}", "fontSize": "{font.size.9}", "lineHeight": "{font.line-height.relaxed}", "letterSpacing": "{font.letter-spacing.normal}" } },

    "eyebrow": { "$type": "typography", "$value": { "fontFamily": "{font.family.mono}", "fontWeight": "{font.weight.regular}", "fontSize": "{font.size.11}", "lineHeight": "{font.line-height.snug}", "letterSpacing": "{font.letter-spacing.wide}", "textCase": "uppercase" }, "$description": "Mono ALL-CAPS section labels (.eyebrow / .secLabel)" },
    "code": { "$type": "typography", "$value": { "fontFamily": "{font.family.mono}", "fontWeight": "{font.weight.regular}", "fontSize": "{font.size.12}", "lineHeight": "{font.line-height.snug}", "letterSpacing": "{font.letter-spacing.normal}" }, "$description": "Code, tokens, hexes, reconcile logs" }
  }
}
