{
  "color": {
    "action": {
      "brand":     {
        "default":  { "$value": "{color.brand.500}", "$type": "color" },
        "hover":    { "$value": "{color.brand.600}", "$type": "color" },
        "active":   { "$value": "{color.brand.700}", "$type": "color" },
        "disabled": { "$value": "{color.brand.200}", "$type": "color" },
        "subtle":   { "$value": "{color.brand.50}",  "$type": "color" }
      },
      "secondary": {
        "default": { "$value": "{color.neutral.200}", "$type": "color" },
        "hover":   { "$value": "{color.neutral.300}", "$type": "color" }
      },
      "danger": {
        "default": { "$value": "{color.red.600}", "$type": "color" },
        "hover":   { "$value": "{color.red.700}", "$type": "color" },
        "subtle":  { "$value": "{color.red.50}",  "$type": "color" }
      },
      "special": {
        "default": { "$value": "{color.blue.600}", "$type": "color" },
        "hover":   { "$value": "{color.blue.700}", "$type": "color" }
      }
    },
    "bg": {
      "page":          { "$value": "{color.neutral.50}",  "$type": "color" },
      "panel":         { "$value": "{color.white}",   "$type": "color" },
      "inset":         { "$value": "{color.neutral.100}", "$type": "color" },
      "subtle":        { "$value": "{color.neutral.200}", "$type": "color" },
      "hover":         { "$value": "{color.neutral.100}", "$type": "color" },
      "brand-subtle":  { "$value": "{color.brand.50}",    "$type": "color" },
      "brand-bold":    { "$value": "{color.brand.500}",   "$type": "color" },
      "special-subtle":{ "$value": "{color.blue.50}",     "$type": "color" },
      "special-bold":  { "$value": "{color.blue.600}",    "$type": "color" },
      "overlay":       { "$value": "rgba(0,0,0,0.45)",    "$type": "color" }
    },
    "text": {
      "primary":   { "$value": "{color.neutral.900}", "$type": "color" },
      "secondary": { "$value": "{color.neutral.500}", "$type": "color" },
      "muted":     { "$value": "{color.neutral.400}", "$type": "color" },
      "disabled":  { "$value": "{color.neutral.300}", "$type": "color" },
      "inverse":   { "$value": "{color.white}",   "$type": "color" },
      "brand":     { "$value": "{color.brand.500}",   "$type": "color" },
      "link":      { "$value": "{color.blue.600}",    "$type": "color" },
      "success":   { "$value": "{color.green.600}",   "$type": "color" },
      "error":     { "$value": "{color.red.600}",     "$type": "color" },
      "warning":   { "$value": "{color.yellow.700}",  "$type": "color" },
      "info":      { "$value": "{color.blue.600}",    "$type": "color" }
    },
    "border": {
      "default": { "$value": "{color.neutral.200}", "$type": "color" },
      "strong":  { "$value": "{color.neutral.300}", "$type": "color" },
      "focus":   { "$value": "{color.sky.400}",     "$type": "color" },
      "brand":   { "$value": "{color.brand.500}",   "$type": "color" },
      "success": { "$value": "{color.green.600}",   "$type": "color" },
      "error":   { "$value": "{color.red.600}",     "$type": "color" },
      "warning": { "$value": "{color.yellow.500}",  "$type": "color" },
      "info":    { "$value": "{color.blue.600}",    "$type": "color" }
    },
    "feedback": {
      "success": {
        "bg":     { "$value": "{color.green.50}",  "$type": "color" },
        "border": { "$value": "{color.green.200}", "$type": "color" },
        "icon":   { "$value": "{color.green.600}", "$type": "color" },
        "text":   { "$value": "{color.green.800}", "$type": "color" }
      },
      "error": {
        "bg":     { "$value": "{color.red.50}",  "$type": "color" },
        "border": { "$value": "{color.red.200}", "$type": "color" },
        "icon":   { "$value": "{color.red.600}", "$type": "color" },
        "text":   { "$value": "{color.red.800}", "$type": "color" }
      },
      "warning": {
        "bg":     { "$value": "{color.yellow.50}",  "$type": "color" },
        "border": { "$value": "{color.yellow.200}", "$type": "color" },
        "icon":   { "$value": "{color.yellow.500}", "$type": "color" },
        "text":   { "$value": "{color.yellow.900}", "$type": "color" }
      },
      "info": {
        "bg":     { "$value": "{color.blue.50}",  "$type": "color" },
        "border": { "$value": "{color.blue.200}", "$type": "color" },
        "icon":   { "$value": "{color.blue.600}", "$type": "color" },
        "text":   { "$value": "{color.blue.900}", "$type": "color" }
      }
    }
  }
}
