      "base": { "$value": "Inter, -apple-system, 'Segoe UI', system-ui, sans-serif", "$type": "fontFamily" },
      "mono": { "$value": "'Fragment Mono', 'JetBrains Mono', monospace", "$type": "fontFamily" }
    },
    "weight": {
      "regular": { "$value": "400", "$type": "fontWeight" },
      "bold":    { "$value": "700", "$type": "fontWeight" }
    },
    "size": {
      "d1": { "$value": "72px", "$type": "dimension" },
      "d2": { "$value": "56px", "$type": "dimension" },
