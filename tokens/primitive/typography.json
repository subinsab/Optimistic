      "b1": { "$value": "18px", "$type": "dimension" },
      "b2": { "$value": "16px", "$type": "dimension" },
      "b3": { "$value": "14px", "$type": "dimension" },
      "b4": { "$value": "12px", "$type": "dimension" },
      "s1": { "$value": "13px", "$type": "dimension" },
