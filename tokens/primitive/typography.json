{
  "font": {
    "family": {
      "base": { "$value": "Inter, -apple-system, 'Segoe UI', system-ui, sans-serif", "$type": "fontFamily", "$description": "Reading + UI. Large sizes use the optical-size axis (Inter Display)." },
      "mono": { "$value": "'Geist Mono', 'JetBrains Mono', monospace", "$type": "fontFamily", "$description": "The machine voice: eyebrows, code, numerals." }
    },
    "weight": {
      "light":    { "$value": "300", "$type": "fontWeight", "$description": "Display / headlines only" },
      "regular":  { "$value": "400", "$type": "fontWeight" },
      "medium":   { "$value": "500", "$type": "fontWeight" },
      "semibold": { "$value": "600", "$type": "fontWeight" },
      "bold":     { "$value": "700", "$type": "fontWeight" }
    },
    "size": {
      "72": { "$value": "72px", "$type": "dimension" },
      "60": { "$value": "60px", "$type": "dimension" },
      "54": { "$value": "54px", "$type": "dimension" },
      "36": { "$value": "36px", "$type": "dimension" },
      "28": { "$value": "28px", "$type": "dimension" },
      "24": { "$value": "24px", "$type": "dimension" },
      "18": { "$value": "18px", "$type": "dimension" },
      "16": { "$value": "16px", "$type": "dimension" },
      "14": { "$value": "14px", "$type": "dimension" },
      "12": { "$value": "12px", "$type": "dimension" },
      "11": { "$value": "11px", "$type": "dimension" },
      "10": { "$value": "10px", "$type": "dimension" },
      "9":  { "$value": "9px",  "$type": "dimension" }
    },
    "line-height": {
      "$description": "Unitless leading, matched to our components: tight for display, loose for body.",
      "display":  { "$value": "1.05", "$type": "number", "$description": "Hero / page titles (.title uses 1.02)" },
      "heading":  { "$value": "1.25", "$type": "number", "$description": "Headers" },
      "snug":     { "$value": "1.35", "$type": "number", "$description": "Sub-headings, eyebrows, code" },
      "relaxed":  { "$value": "1.6",  "$type": "number", "$description": "Body reading text (.lead uses 1.65)" }
    },
    "letter-spacing": {
      "display": { "$value": "-0.03em", "$type": "dimension", "$description": "Light display headlines (.title)" },
      "tight":   { "$value": "-0.02em", "$type": "dimension", "$description": "Large headers" },
      "snug":    { "$value": "-0.01em", "$type": "dimension", "$description": "Small headers, sub-headings" },
      "normal":  { "$value": "0em",     "$type": "dimension", "$description": "Body" },
      "wide":    { "$value": "0.2em",   "$type": "dimension", "$description": "Mono eyebrows, uppercase (.eyebrow)" }
    }
  }
}
