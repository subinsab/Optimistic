{
  "badge": {
    "radius":    { "$value": "{radius.full}",      "$type": "dimension" },
    "padding-x": { "$value": "{space.100}",        "$type": "dimension" },
    "padding-y": { "$value": "{space.025}",        "$type": "dimension" },
    "gap":       { "$value": "{space.050}",        "$type": "dimension" },
    "font":      { "$value": "{text-style.body-3}", "$type": "typography" },
    "neutral": {
      "bg":     { "$value": "{color.bg.inset}",       "$type": "color" },
      "border": { "$value": "{color.border.default}", "$type": "color" },
      "text":   { "$value": "{color.text.secondary}", "$type": "color" }
    },
    "success": {
      "bg":     { "$value": "{color.feedback.success.bg}",     "$type": "color" },
      "border": { "$value": "{color.feedback.success.border}", "$type": "color" },
      "text":   { "$value": "{color.feedback.success.text}",   "$type": "color" }
    },
    "error": {
      "bg":     { "$value": "{color.feedback.error.bg}",     "$type": "color" },
      "border": { "$value": "{color.feedback.error.border}", "$type": "color" },
      "text":   { "$value": "{color.feedback.error.text}",   "$type": "color" }
    },
    "warning": {
      "bg":     { "$value": "{color.feedback.warning.bg}",     "$type": "color" },
      "border": { "$value": "{color.feedback.warning.border}", "$type": "color" },
      "text":   { "$value": "{color.feedback.warning.text}",   "$type": "color" }
    },
    "info": {
      "bg":     { "$value": "{color.feedback.info.bg}",     "$type": "color" },
      "border": { "$value": "{color.feedback.info.border}", "$type": "color" },
      "text":   { "$value": "{color.feedback.info.text}",   "$type": "color" }
    }
  }
}
