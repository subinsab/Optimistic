{
  "button": {
    "radius":        { "$value": "{radius.md}", "$type": "dimension" },
    "font":          { "$value": "{text-style.label}", "$type": "typography" },
    "gap":           { "$value": "{space.100}", "$type": "dimension" },
    "size": {
      "sm": { "height": { "$value": "{size.control.sm}", "$type": "dimension" }, "padding-x": { "$value": "{space.150}", "$type": "dimension" }, "padding-y": { "$value": "{space.075}", "$type": "dimension" } },
      "md": { "height": { "$value": "{size.control.md}", "$type": "dimension" }, "padding-x": { "$value": "{space.200}", "$type": "dimension" }, "padding-y": { "$value": "{space.100}", "$type": "dimension" } },
      "lg": { "height": { "$value": "{size.control.lg}", "$type": "dimension" }, "padding-x": { "$value": "{space.300}", "$type": "dimension" }, "padding-y": { "$value": "{space.150}", "$type": "dimension" } }
    },
    "primary": {
      "bg":       { "$value": "{color.action.brand.default}", "$type": "color" },
      "bg-hover": { "$value": "{color.action.brand.hover}",   "$type": "color" },
      "bg-active":{ "$value": "{color.action.brand.active}",  "$type": "color" },
      "text":     { "$value": "{color.text.inverse}",         "$type": "color" }
    },
    "secondary": {
      "bg":       { "$value": "{color.bg.panel}",      "$type": "color" },
      "bg-hover": { "$value": "{color.bg.hover}",      "$type": "color" },
      "text":     { "$value": "{color.text.primary}",  "$type": "color" },
      "border":   { "$value": "{color.border.default}","$type": "color" }
    },
    "danger": {
      "bg":       { "$value": "{color.action.danger.default}", "$type": "color" },
      "bg-hover": { "$value": "{color.action.danger.hover}",   "$type": "color" },
      "text":     { "$value": "{color.text.inverse}",          "$type": "color" }
    },
    "ghost": {
      "bg-hover": { "$value": "{color.bg.hover}",      "$type": "color" },
      "text":     { "$value": "{color.text.secondary}","$type": "color" }
    },
    "link": {
      "text": { "$value": "{color.text.link}", "$type": "color" }
    }
  }
}
