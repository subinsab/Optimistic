{
  "input": {
    "height":      { "$value": "{size.control.input}",   "$type": "dimension" },
    "radius":      { "$value": "{radius.md}",             "$type": "dimension" },
    "padding-x":   { "$value": "{space.150}",             "$type": "dimension" },
    "padding-y":   { "$value": "{space.100}",             "$type": "dimension" },
    "font":        { "$value": "{text-style.body-2}",     "$type": "typography" },
    "bg":          { "$value": "{color.bg.panel}",        "$type": "color" },
    "text":        { "$value": "{color.text.primary}",    "$type": "color" },
    "placeholder": { "$value": "{color.text.muted}",      "$type": "color" },
    "border":      { "$value": "{color.border.default}",  "$type": "color" },
    "border-hover":{ "$value": "{color.border.strong}",   "$type": "color" },
    "border-focus":{ "$value": "{color.border.focus}",    "$type": "color" },
    "border-error":{ "$value": "{color.border.error}",    "$type": "color" },
    "ring-focus":  { "$value": "{shadow.focus}",          "$type": "shadow" },
    "ring-error":  { "$value": "{shadow.focus-error}",    "$type": "shadow" },
    "disabled-bg": { "$value": "{color.bg.subtle}",       "$type": "color" },
    "disabled-text":{ "$value": "{color.text.disabled}",  "$type": "color" },
    "label": {
      "font": { "$value": "{text-style.body-2}", "$type": "typography" },
      "text": { "$value": "{color.text.primary}", "$type": "color" },
      "gap":  { "$value": "{space.050}", "$type": "dimension" }
    },
    "helper": {
      "font":  { "$value": "{text-style.body-3}", "$type": "typography" },
      "text":  { "$value": "{color.text.secondary}", "$type": "color" },
      "error": { "$value": "{color.text.error}", "$type": "color" },
      "gap":   { "$value": "{space.050}", "$type": "dimension" }
    }
  }
}
